# ProbeFlash user-dir no-sudo deployment environment.
# Copy to /home/hurricane/probeflash/shared/env/probeflash.env and keep it outside release directories.
# A later authorized systemd unit can read the same file through EnvironmentFile=.

# LAN deployment: listen on all interfaces. Local-only smoke can temporarily use 127.0.0.1.
PROBEFLASH_HOST=0.0.0.0

# Independent port. Do not use 80; it is already occupied by an existing web service.
PROBEFLASH_PORT=4100

# Persistent SQLite file. The Node process creates parent directories when permitted.
PROBEFLASH_DB_PATH=/home/hurricane/probeflash/shared/data/probeflash.sqlite

# Log directory reserved for no-sudo process logs, later systemd append targets, and future log export.
PROBEFLASH_LOG_DIR=/home/hurricane/probeflash/shared/logs

# Default S3 workspace seed. Keep projectId/workspaceId aligned during S3 compatibility period.
PROBEFLASH_WORKSPACE_ID=workspace-26-r1
PROBEFLASH_WORKSPACE_NAME=26年 R1
