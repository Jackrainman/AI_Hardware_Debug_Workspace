{
  "name": "@probeflash/desktop",
  "private": true,
  "version": "0.0.1",
  "description": "ProbeFlash desktop shell for embedded debugging flash notes and knowledge archiving.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify:handoff": "node --experimental-strip-types scripts/verify-handoff-json.mts",
    "verify:s1-a3": "node --experimental-strip-types scripts/verify-s1-a3.mts",
    "verify:s2-a1": "node --experimental-strip-types scripts/verify-s2-a1.mts",
    "verify:s2-a2": "node --experimental-strip-types scripts/verify-s2-a2.mts",
    "verify:s2-a3": "node --experimental-strip-types scripts/verify-s2-a3.mts",
    "verify:s2-a4": "node --experimental-strip-types scripts/verify-s2-a4.mts",
    "verify:d1-archive-persist-index": "node --experimental-strip-types scripts/verify-d1-archive-persist-index.mts",
    "verify:s3-arch-async-storage-port": "node --experimental-strip-types scripts/verify-s3-arch-async-storage-port.mts",
    "verify:s3-arch-closeout-orchestrator": "node --experimental-strip-types scripts/verify-s3-arch-closeout-orchestrator.mts",
    "verify:s3-arch-unified-storage-error-state": "node --experimental-strip-types scripts/verify-s3-arch-unified-storage-error-state.mts",
    "verify:all": "npm run verify:handoff && npm run verify:s1-a3 && npm run verify:s2-a1 && npm run verify:s2-a2 && npm run verify:s2-a3 && npm run verify:s2-a4 && npm run verify:d1-archive-persist-index && npm run verify:s3-arch-async-storage-port && npm run verify:s3-arch-closeout-orchestrator && npm run verify:s3-arch-unified-storage-error-state && npm run verify:s3-local-http-storage-adapter && npm run verify:s3-local-end-to-end",
    "verify:s3-local-http-storage-adapter": "node --experimental-strip-types scripts/verify-s3-local-http-storage-adapter.mts",
    "verify:s3-local-end-to-end": "node --experimental-strip-types scripts/verify-s3-local-end-to-end.mts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
