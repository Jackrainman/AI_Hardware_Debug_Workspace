{
  "permissions": {
    "defaultMode": "auto",
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(npm -v)",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npx *)",
      "Bash(git --version)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit -m *)",
      "Bash(python *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./*.key)",
      "Read(./*.pem)",
      "Read(./*.p12)",
      "Read(./*.jks)",
      "Read(./id_rsa)",
      "Read(./id_ed25519)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyRead": ["~/"],
      "allowRead": [".", "~/.nvm", "~/.npm", "~/.cache", "/tmp"],
      "allowWrite": [".", "~/.npm", "~/.cache", "/tmp"]
    }
  }
}
